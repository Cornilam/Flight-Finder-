# =============================================================================
# Flight Deal Finder - Hacker Fare Engine
# =============================================================================
# Copy this file to .env and fill in your API keys.
#
# Amadeus API (test environment - free tier, 500 calls/month)
#   Sign up at: https://developers.amadeus.com/
#   Create a "Self-Service" app to get your key and secret.
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# =============================================================================
# Trip Configuration
# =============================================================================
ORIGIN=MKE
DESTINATION=ATH
DEPART_DATE=2026-05-22
RETURN_DATE=2026-05-30

# =============================================================================
# Hub Tiers (comma-separated IATA codes)
# =============================================================================
# QUICK: Best-connected airports for transatlantic travel (~17 API calls)
HUBS_QUICK=JFK,EWR,IAD,ORD,ATL,CLT,PHL,YYZ

# DEEP: All quick hubs PLUS additional gateways (~51 API calls)
HUBS_DEEP=JFK,EWR,IAD,ORD,ATL,CLT,PHL,YYZ,BOS,DCA,MIA,DTW,MSP,DFW,IAH,SFO,LAX,YUL,IST,FRA,CDG,AMS,ZRH,FLL,MCO

# Legacy key (kept for CLI backward compatibility)
HUBS=JFK,EWR,IAD,ORD,ATL,CLT,PHL,YYZ

# Minimum connection time in minutes between separate tickets
MIN_CONNECTION_MINUTES=120

# =============================================================================
# Drive-to-Hub Configuration
# =============================================================================
REGIONAL_AIRPORT=MKE
HUB_AIRPORT=ORD
DRIVING_COST=100.00
PARKING_RATE_PER_DAY=20.00
DRIVE_TIME_MINUTES=90
TIME_VALUE_PER_HOUR=0.00
