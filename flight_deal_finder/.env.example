# =============================================================================
# Hacker Fare Engine - Configuration
# =============================================================================
# Copy this file to .env and fill in your API key.
#
# SerpAPI (Google Flights data - free tier: 250 searches/month)
#   Sign up at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# =============================================================================
# Trip Configuration
# =============================================================================
ORIGIN=MKE
DESTINATION=ATH
DEPART_DATE=2026-05-22
RETURN_DATE=2026-05-30

# =============================================================================
# Hub Airports (comma-separated IATA codes)
# =============================================================================
# Each hub adds ~4 API calls per search. 5 hubs = ~21 calls.
SERP_HUBS=JFK,EWR,ORD,IAD,ATL

# Minimum connection time in minutes between separate tickets
MIN_CONNECTION_MINUTES=120

# =============================================================================
# Drive-to-Hub Comparison
# =============================================================================
# Compare flying from home airport vs driving to a nearby hub
HUB_AIRPORT=ORD
DRIVING_COST=100.00
PARKING_RATE_PER_DAY=20.00
